# ─────────────────────────────────────────────────────────────────────────────
# Nox Trading Engine — environment variable reference
# Copy this file to .env and fill in your values before running docker compose.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared auth token (all internal containers authenticate with this) ────────
WEBHOOK_SECRET_TOKEN=your_secret_token_here

# ── Alpaca Markets ────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
# Paper trading:  https://paper-api.alpaca.markets
# Live trading:   https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Telegram bot (system alerts and Analyst reports) ─────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Anthropic (heartbeat NLP analysis) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Kelly position sizing ─────────────────────────────────────────────────────
# Derived from your walk-forward OOS results (run backtest-engine/walk_forward.sh).
# KELLY_FRACTION scales raw Kelly before the 10 % hard cap (see main.cpp comments).
KELLY_WIN_RATE=0.6842
KELLY_WIN_LOSS_RATIO=2.316
KELLY_FRACTION=0.15

# ── Shared watchlist (propagates to america-data-engine and heartbeat) ────────
# US companies (file 8-K) and Chinese ADRs (file 6-K) are kept separate because
# the heartbeat uses different SEC feeds for each category.
# Add/remove tickers here; all services pick up the change on next restart.
NOX_WATCHLIST_US=AAPL,TSLA,NVDA,MSFT
NOX_WATCHLIST_CN=BABA,JD,PDD,BIDU,NIO
# Optional: limit which tickers the heartbeat pulls SEC filings for in the daily report.
# Keep this focused to 6-8 names for best Claude prompt reliability.
# NOX_DAILY_REPORT_TICKERS=AAPL,TSLA,NVDA,MSFT,BABA,JD,PDD,BIDU
# MAX_DAILY_REPORT_SEC_TICKERS=8

# ── Analyst cycle ─────────────────────────────────────────────────────────────
ANALYST_CYCLE_HOURS=6

# ── Options scanner ───────────────────────────────────────────────────────────
OPTIONS_BOT_AUTO_EXECUTE=false
OPTIONS_BOT_MAX_SIGNALS=3
OPTIONS_PERSONAL_MAX_SIGNALS=2
# OPTIONS_BOT_WATCHLIST=SPY,QQQ,AAPL,TSLA,NVDA
# OPTIONS_PERSONAL_WATCHLIST=SPY,QQQ,AAPL,TSLA,NVDA,AMZN,META
# OPTIONS_BOT_FREE_CAPITAL_AMOUNT=0.0
# OPTIONS_BOT_SCAN_INTERVAL_MINUTES=30

# ── Persistence (execution engine) ───────────────────────────────────────────
# These default to /app/data (the volume-mounted ./data directory).
# Override only if you change the volume mount.
# MEMORY_BANK_PATH=/app/data/memory_bank.db
# CN_POSITIONS_PATH=/app/data/china_positions.json

# ── Chinese A-share rules ─────────────────────────────────────────────────────
# CN_BOARD_LOT_SIZE=100   # set to 100 for CN A-share exchanges (1手); default is 1 (all US equities)

# ── WS1 — Contradiction Vector ───────────────────────────────────────────────
HEARTBEAT_BASE_URL=http://heartbeat-monitor:8002
# CONTRADICTION_SKEW_THRESHOLD=0.03
# CONTRADICTION_SENTIMENT_THRESHOLD=0.25
# CONTRADICTION_BYPASS=false    # set true to disable in backtests

# ── WS2 — Alternative Macro Pipeline ─────────────────────────────────────────
# Marine war-risk insurance and AIS tanker traffic feeds (paid/proprietary).
# Leave blank to use the inline manual JSON fallback defined in alt_macro.py.
# ALT_INSURANCE_URL=
# ALT_INSURANCE_JSON=
# ALT_AIS_URL=
# ALT_AIS_JSON=
# OFAC_ACTIONS_URL=https://ofac.treasury.gov/system/files/126/ofac.xml
# ALT_MACRO_BYPASS=false

# ── WS3 — Insider Cluster Filter (SEC Form 4) ─────────────────────────────────
# SEC EDGAR requires a descriptive User-Agent or returns 403.
SEC_USER_AGENT=YourName/1.0 your@email.com
# INSIDER_CLUSTER_WINDOW_HOURS=48
# INSIDER_MIN_EXECS=2
# INSIDER_CLUSTER_BYPASS=false

# ── WS4 — Information Half-Life / Regime Decay ───────────────────────────────
# HALFLIFE_DECAY_BYPASS=false   # set true to pass raw scores in backtests
# REGIME_RESET_BYPASS=false
# CATALYST_VIX_JUMP=5.0         # VIX jump threshold that triggers a regime reset

# ── WS5 — Liquidity Vacuum / Microstructure Gate ─────────────────────────────
# LIQUIDITY_GATE_STDDEV=3.0     # z-score threshold (N σ above baseline)
# LIQUIDITY_GATE_WINDOW=50      # rolling window size (observations per symbol)
# LIQUIDITY_GATE_MIN_SAMPLES=10 # warm-up period before gate activates
# LIQUIDITY_GATE_BYPASS=false   # set true to disable gate in backtests

# ── WS6 — Weekend Research Batch ─────────────────────────────────────────────
# Reports are written to ./data/skeptic_report_YYYY-MM-DD.{json,md}
# No additional config needed beyond the volume mount in docker-compose.yml.

# ── Heartbeat IV endpoint ─────────────────────────────────────────────────────
# HEARTBEAT_IV_PORT=8002        # internal port for IV skew endpoint
