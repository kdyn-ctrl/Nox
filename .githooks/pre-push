#!/usr/bin/env bash
# Blocks pushes to the public showcase repo (upstream/Nox) that would leak
# private edge (IBKR code, curated tuning/watchlists, personal PII).
#
# Enable with:  git config core.hooksPath .githooks
#
# Only enforced when pushing to a remote named "upstream" or whose URL
# points at kdyn-ctrl/Nox — pushes to the private remote are unaffected.
set -euo pipefail

remote_name="$1"
remote_url="$2"

if [[ "$remote_name" != "upstream" && "$remote_url" != *"kdyn-ctrl/Nox"* ]]; then
  exit 0
fi

root="$(git rev-parse --show-toplevel)"
zero="0000000000000000000000000000000000000000"
fail=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_sha" == "$zero" ]] && continue  # branch deletion, nothing to check

  base="$remote_sha"
  [[ "$base" == "$zero" ]] && base=""  # new branch on the remote — scan full tree

  if ! "$root/scripts/check_public_safe.sh" "$local_sha" "$base"; then
    fail=1
  fi
done

if [[ "$fail" -ne 0 ]]; then
  echo "[pre-push] Push to '${remote_name}' blocked by check_public_safe.sh." >&2
  exit 1
fi
